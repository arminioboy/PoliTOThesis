* 1EDB7275F Single-channel isolated gate-driver ICs
*! Name: 1EDB7275F
*! Version: 1.11-2020-10-08

*! Library references
*! Library name, version
*! Gate_Driver.lib, 2020-10-08

*! Change history of model
*! Version, Changes
*! 1.0-2020-03-06, base model creation
*! 1.1-2020-06-11, Better output current, Activation time of output clamping, Start-up, 
*!                 deactivation times, UVLO temperature dependence  
*! 1.11-2020-10-08, Output current slope has been adjusted

.PARAM DOUT_HIGH= {5}

.SUBCKT 1EDB7275F OUT_SRC VDDO IN+ GNDI VDDI Tj Tamb Tc IN- OUT_SNK GNDO
+ Params: THERMAL_MODEL=1 ; 0 = External case to ambient thermal model, 1 = Internal case to ambient thermal model 
XU1 OUT_SRC VDDO IN+ GNDI VDDI Tj Tamb Tc IN- OUT_SNK GNDO 1EDB7275F_0 Params: THERMAL_MODEL={THERMAL_MODEL}
.ENDS

.SUBCKT 1EDB7275F_0 OUT_SRC VDDO IN+ GNDI VDDI Tj Tamb Tc IN- OUT_SNK GNDO
+ Params: THERMAL_MODEL=1 ; 0 = External case to ambient thermal model, 1 = Internal case to ambient thermal model
.PARAM Ion= {1.691997E-02}
.PARAM Ioff= {1.785997E-02}
.PARAM DTcoff= {-0.001u}
.PARAM DTcon= {-0.001u}
.PARAM DOUT_HIGH= {5}
.PARAM Kiqin= {-0.085m/DOUT_HIGH}
.PARAM YN= {7}
.PARAM Kiddslope= {-0.004m/DOUT_HIGH}
.PARAM MN= {13}
.PARAM WN= {97.552121u}
.PARAM L_N= {1000n}
.PARAM LAMBDAN= {23.148148m}
.PARAM VTHN= {1}
.PARAM RDN= {124.783609m}
.PARAM KPN= {388.478677u}
.PARAM VGSmaxN= {6.463505}
.PARAM TCRN= {1.561739m}
.PARAM LAMBDAP= {15.151515m}
.PARAM VTHP= {-1}
.PARAM MP= {5}
.PARAM WP= {96.857596u}
.PARAM KPP= {388.478677u}
.PARAM RDP= {352.431m}
.PARAM LP= {1000n}
.PARAM VGSmaxP= {7.920998}
.PARAM TCRP= {3.022m}
.PARAM CgdP= {500.469021f}
.PARAM CgsP= {10p}
.PARAM CdsP= {20p}
.PARAM CgdN= {1190.469021f}
.PARAM CgsN= {15p}
.PARAM CdsN= {20p}
.PARAM VD01= {(N*Vtn)*Log(Ioff/IS + 1) + RS*Ioff}
.PARAM N= {0.1}
.PARAM Vtn= {26m}
.PARAM IS= {10f}
.PARAM RS= {10}
.PARAM TCbias= {-400u}
VS6         29 30 1.1
VS5         25 31 3.3

*VCIb2I      30 GNDI ; Current Arrow
*VCIb1I      33 GNDI ; Current Arrow
*VS3         32 33 1.2
*VIhmosA     37 OUT_SRC ; Current Arrow
*VIlmosA     OUT_SNK 38 ; Current Arrow
*VCIb1       44 GNDO ; Current Arrow

* Current sense sources stabilized

VCIb2I      30 N_VCIb2I 0
R_VCIb2I    N_VCIb2I GNDI 1m

VCIb1I      33 N_VCIb1I 0
R_VCIb1I    N_VCIb1I GNDI 1m

VS3         32 33 1.2

VIhmosA     37 N_VIhmosA 0
R_VIhmosA   N_VIhmosA OUT_SRC 1m

VIlmosA     OUT_SNK N_VIlmosA 0
R_VIlmosA   N_VIlmosA 38 1m

VCIb1       44 N_VCIb1 0
R_VCIb1     N_VCIb1 GNDO 1m
*end stabilized current sense sources

VS2         53 44 1.15
IT25        0 46 25M
XU7         VDDO GNDO 18 DGND Tj HYSTCOMPG_THLRF_LONGDEL_1EDB7275F_0
+ PARAMS: VTHRES=0 VHYST=1 VOUTH=5 VOUTL=0 ROUT=100 TDLH=4.8U TDHL=80N TRISE=1N
+ TFALL=1N Y={YN}
