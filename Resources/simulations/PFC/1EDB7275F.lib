.SUBCKT HYSTCOMPG_THLRF_TVIN_TEMP_1EDB7275F_0 inp inm out gnd Tj
+ Params: VoutH=5 VoutL=0 Rout=1 Tdlh=1N Tdhl=1N Trise=1N Tfall=1N Tslh=1n Tshl=1n Vinmax=5 Vinmin=3
* Trise ->   90%*(VoutH-VoutL), Tfall -> 10%*(VoutH-VoutL)
.PARAM MinADel = 100p
.PARAM Tdellh = {MAX(Tdlh,MinADel)}
.PARAM Tdelhl = {MAX(Tdhl,MinADel)}
.Param Rdel = {IF ( ((Tdellh > 1E-15)|(Tdelhl > 1E-15)) & (Rout < 1), 1, Rout ) } 
.Param Ro = {IF ( ((Trise > 1E-15)|(Tfall > 1E-15)) & (Rout < 1), 1, Rout ) } 
.Param VoutM={(VoutH+VoutL)/2}
*.Param VthH={Vthres+Vhyst}
*.Param VthL={Vthres-Vhyst}
.Param Tdmin= 1p
.Param Cdel={Sqrt((Tdelhl+Tdmin)*(Tdellh+Tdmin))/(0.693*(Rdel+1u))}
.Param Gdlh={Sqrt((Tdelhl+Tdmin)/(Tdellh+Tdmin))/Rdel}
.Param Gdhl={(Tdellh+Tdmin)/(Tdelhl+Tdmin)*Gdlh}
.Param Cio= {IF ( Abs(Tshl) > Abs(Tslh), Cdel*Tshl/Tdelhl/(Vinmax-Vinmin), Cdel*Tslh/Tdellh/(Vinmax-Vinmin))}
.Param Khl= {IF ( Abs(Tshl) > Abs(Tslh), 1, Tshl/Tslh)}
.Param Klh= {IF ( Abs(Tshl) > Abs(Tslh), Tslh/Tshl, 1)}
.Param Cout={Sqrt(Tfall*Trise)/(2.287*(Ro+1u))}
.Param Gr={Sqrt(Tfall/(Trise+Tdmin))/Ro}
.Param Gf={(Trise+Tdmin)/Tfall*Gr}
.Param Inv= -1

EVthrH VthrH 0 table {V(Tj,gnd)} = (-40, 2.1497, -20, 2.1503, 0, 2.1598, 25, 2.1605, 50, 2.1568, 100, 2.1449, 150, 2.1198)
EVthrL VthrL 0 table {V(Tj,gnd)} = (-40, 1.2932, -25, 1.2936, 0, 1.2899, 25, 1.2907, 50, 1.2869, 100, 1.2751, 150, 1.2544)

Rinp inp gnd 1G
Rinm inm gnd 1G
*Gthr gnd thr Value= { IF ( V(out,gnd) < {VoutM}, {VthH}, {VthL}) }
*Gthr gnd thr Value= { IF ( V(out,gnd) < VoutM, V(VthrH), V(VthrL) ) }
Gthr gnd thr Value= { IF ( Inv*(V(out,gnd) - VoutM) < 0, V(VthrH), V(VthrL) ) }
Rthr gnd thr 1
Gouti gnd outi Value= { IF ( (V(inp,inm) > V(thr,gnd)), (VoutH - V(outi,gnd))*Gdlh, (VoutL - V(outi,gnd))*Gdhl ) }
Couti outi gnd {Cdel}
Routi outi gnd 1G
Gtm gnd tm  Value= {1/(Abs(V(inp,inm)-V(thr,gnd)) + 1m)}
Rtm tm gnd {1}
Ctm tm gnd {Cdel*Rdel}

Gin gnd ini Value= { Limit(V(inp,inm) - Vinmin, 0, Vinmax-Vinmin)*(IF ( Inv*(V(out,gnd) - VoutM) > 0, Khl, Klh) ) }
Rin gnd ini 1
Cio ini outi {Cio}
Gout gnd out Value= { IF ( Inv*(V(outi, gnd) - VoutM) > 0, (VoutH - V(out,gnd))*Gr, (VoutL - V(out,gnd))*Gf ) }
Cout out gnd {Cout}
Rout out gnd 1G
.ENDS

