+ PARAMS: VOUTH=5 VOUTL=0 ROUT=100 TDLH=19N TDHL=19N TRISE=1N TFALL=1N VINMAX=5
+ TSLH=-0.25N TSHL=1.0N VINMIN=3
XD5         GNDI IN- D_Z_17_1N_0
XU4         27 28 DPWR DGND AD_BUF_DP_0
+ PARAMS: DLH = 0 DHL = 0
XD23        GNDI VDDI D_Z_17_3_0
XD18        29 25 D_LIM10_0
R26         25 30 10MEG 
XD17        VDDI 25 D_LIM10_0
XD16        31 30 D_LIM10_0
GVCCS11     25 30 VALUE = {(V(VDDI,GNDI)-3.3)*100M}
XD11        32 26 D_LIM10_0
XD12        VDDI 26 D_LIM10_0
GVCCS9      26 33 VALUE = {V(34,GNDI)}
GVCCS8      GNDI 34 VALUE = {0.80228M+V(TJ25,0)*0.000798M}
R25         34 GNDI 1 
R24         26 33 10MEG 
XD24        GNDO VDDO D_Z_22_3_0
C3          GNDI GNDO  1.5P
R27         GNDI GNDO 10G 
XQ1         37 VhgA VDDO VDDO Tj SWMOSP_0
+ PARAMS: VTH={VTHP} KP={KPP} M={MP} W={WP} L={LP} LAMBDA={LAMBDAP} RD={RDP}
+ CGD={CgdP} CGS={CgsP} TCR={TCRP} CDS={CdsP}
XQ4         38 VlgA GNDO GNDO Tj SWMOSN_0
+ PARAMS: VTH={VTHN} KP={KPN} M={MN} W={WN} L={L_N} LAMBDA={LAMBDAN} RD={RDN}
+ CGD={CgdN} CGS={CgsN} TCR={TCRN} CDS={CdsN}
XD19        GNDI IN+ D_Z_17_1N_0
XAND2_P2    39 VDDIUVLO GDIA DPWR DGND AND2_P
+ PARAMS: DLH=5n DHL=4n
XU11        19 VDDIUVLO DPWR DGND AD_BUF_DP_0
+ PARAMS: DLH = 0 DHL = 0
XAND1       41 42 28 39 DPWR DGND AND3_DP_0
+ PARAMS: DLH=12N DHL=12.0N
XU2         43 42 DPWR DGND AD_BUF_DP_0
+ PARAMS: DLH = 0 DHL = 0
XU17        18 41 DPWR DGND AD_BUF_DP_0
+ PARAMS: DLH = 0 DHL = 0
XU1         IN+ GNDI 43 DGND Tj HYSTCOMPG_THLRF_TVIN_TEMP_1EDB7275F_1
+ PARAMS: VOUTH=5 VOUTL=0 ROUT=100 TDLH=19N TDHL=19N TRISE=1N TFALL=1N
Rina        IN+ GNDI 75K 
GIb1        23 44 VALUE = {V(54,GNDO)*(V(TJ25,0)*((0.000028*V(49,DGND)/5)+0.0002)+1)}
GPORO       GNDO 45 VALUE = {LIMIT(I(VCIB1),0,500U*(TCbias*V(TJ25,0)+1.0))}
R22         OUT_SNK VlgA 10MEG 
R2          TJ25 0 1K 
GTD25       0 TJ25 VALUE = {(LIMIT(V(Tj,0),-50,150)-25)*1M}
XU12        Tj Tamb 47 Tc PT THERMALINJECTION4R_0
+ PARAMS: RTHJA25=88 RTHJCTOP25=54 RTHJB25=37 CTJ=4.9981M CTC=136.3155M
+ THERMAL_MODEL={THERMAL_MODEL} DC=1 CTB=213.280684M RTCA=5K
XINV5       48 49 DPWR DGND DA_BUF_DP_0
+ PARAMS: DLH=0N DHL=0N OUT_LOW=0.0 OUT_HIGH=1.0 ROUT=1 COUT=0
XU15        GDIA 50 DPWR DGND INV_DP_0
+ PARAMS: DLH=0N DHL=0N
XINV1       51 52 DPWR DGND DA_BUF_DP_0
+ PARAMS: DLH=0N DHL=0N OUT_LOW=0.0 OUT_HIGH=1.0 ROUT=1 COUT=0
GIhonA      VhgA Vghmx VALUE = {IF(V(49,DGND)>0.5,V(56,0),0)}
GIlonA      Vglmx VlgA VALUE = {IF(V(52,DGND)>0.5,V(55,0),0)}
R1          VhgA VDDO 1G 
GIhoffA     VDDO VhgA VALUE = {IF(V(49,DGND)<0.5,V(56,0),0)}
XD4         Vghmx VhgA D_LIM01_0
XD3         VhgA VDDO D_LIM01_0
XD1         GNDO VlgA D_LIM01_0
XD2         VlgA Vglmx D_LIM01_0
GIloffA     VlgA GNDO VALUE = {IF(V(52,DGND)<0.5,V(55,0),0)}
Rp2         VlgA GNDO 100MEG 
XU13        50 DGND 51 DPWR LEB_0
+ PARAMS: LEB=4.0N
XU8         GDIA DGND 48 DPWR LEB_0
+ PARAMS: LEB=4.0N
EPT         PT 0 VALUE = {ABS(V(OUT_SNK,GNDO)*I(VILMOSA))+ABS(V(VDDO,OUT_SRC)*I(VIHMOSA))+
+ABS(V(VDDO,GNDO)*I(VCIB1))+ABS(V(VDDI,GNDI)*I(VCIB1I))}
GVSVghmx    GNDO Vghmx VALUE = {V(VDDO,GNDO)-V(45,GNDO)*(VGSMAXP-VD01)}
R10         Vghmx GNDO 1 
R9          VDDO Vglmx 1 
GVSVglmx    Vglmx VDDO VALUE = {V(VDDO,GNDO)-V(45,GNDO)*(VGSMAXN-VD01)}
C1          45 GNDO  20P
R7          45 GNDO 2K 
R6          53 44 1MEG 
XD20        53 23 D_LIM0_5_0
GVCCS1      GNDO 54 VALUE = {(0.0085M*V(49,DGND)/5+0.0115M)*V(VDDO,GNDO)+(0.08M*V(49,DGND)/5+0.648158M)-
+(0.102M*V(49,DGND)/5+0.138M)}
Rb3         54 GNDO 1 
Rpsrr1      23 44 10MEG 
R5          55 0 1 
GVCCS4      0 55 VALUE = {IF(V(18,DGND)>2.5,1,V(20,0))*IOFF*(-DTCOFF*V(TJ25,0)+1)}
R4          56 0 1 
GVCCS3      0 56 VALUE = {IF(V(18,DGND)>2.5,1,V(20,0))*ION*(-DTCON*V(TJ25,0)+1)}
R3          46 0 1K 
XDPWR       0 DPWR DGND DIGIFPWR_NOOPNODE
+ PARAMS: VOLTAGE={DOUT_HIGH} REFERENCE=0 

*.MODEL S_VSWITCH_1 VSWITCH (RON=1 ROFF=100MEG VON=1.4 VOFF=10M)
.MODEL S_VSWITCH_1 VSWITCH (RON=1 ROFF=150MEG VON=1.4 VOFF=10M)
.ENDS

.SUBCKT HYSTCOMPG_THLRF_LONGDEL_1EDB7275F_0 inp inm out gnd Tj
+ Params: Vthres=0 Vhyst=1 VoutH=5 VoutL=0 Rout=1 Tdlh=1N Tdhl=1N Trise=1N Tfall=1N Y=7
* Trise ->   90%*(VoutH-VoutL), Tfall -> 10%*(VoutH-VoutL)
.PARAM MinADel = 100p
.PARAM Tdellh = {MAX(Tdlh,MinADel)}
.PARAM Tdelhl = {MAX(Tdhl,MinADel)}
.Param Rdel = {IF ( ((Tdellh > 1E-15)|(Tdelhl > 1E-15)) & (Rout < 1), 1, Rout ) } 
.Param Ro = {IF ( ((Trise > 1E-15)|(Tfall > 1E-15)) & (Rout < 1), 1, Rout ) } 
.Param VoutM={(VoutH+VoutL)/2}
*.Param VthH={Vthres+Vhyst}
*.Param VthL={Vthres-Vhyst}
.Param Tdmin= 1p
*.Param Cdel={Sqrt((Tdelhl+Tdmin)*(Tdellh+Tdmin))/(0.693*(Rdel+1u))}
*.Param Cdel={Sqrt((Tdelhl+Tdmin)*(Tdellh+Tdmin))/(4.6*(Rdel+1u))}
.Param Cdel={Sqrt((Tdelhl+Tdmin)*(Tdellh+Tdmin))/(4.3*(Rdel+1u))}
.Param Gdlh={Sqrt((Tdelhl+Tdmin)/(Tdellh+Tdmin))/Rdel}
.Param Gdhl={(Tdellh+Tdmin)/(Tdelhl+Tdmin)*Gdlh}
.Param Cout={Sqrt(Tfall*Trise)/(2.287*(Ro+1u))}
.Param Gr={Sqrt(Tfall/(Trise+Tdmin))/Ro}
.Param Gf={(Trise+Tdmin)/Tfall*Gr}

*1EDB6
EVthrH6 VthrH6 0 value = {12.2}
EVthrL6 VthrL6 0 value = {11.5}
*1EDB7
EVthrH7 VthrH7 0 table {V(Tj,gnd)} = (-40.05, 4.1473, 0, 4.1501, 25.12, 4.1516, 50.24, 4.1516, 100.12, 4.1516, 150, 4.146)
EVthrL7 VthrL7 0 table {V(Tj,gnd)} = (-40.05, 3.8858, 0, 3.8915, 25.12, 3.8929, 50.24, 3.8943, 100.12, 3.8971, 129.61, 3.9014,
+ 150, 3.8929)

*1EDB8
EVthrH8 VthrH8 0 table {V(Tj,gnd)} = (-40, 7.961, 0, 7.99, 24.815, 7.99, 50, 7.989, 100, 7.988, 150, 7.986)
EVthrL8 VthrL8 0 table {V(Tj,gnd)} = (-40, 6.988, 0, 7.004, 24.815, 7.008, 50, 7.012, 100, 7.019, 150, 7.026)

*1EDB9
*EVthrH9 VthrH9 0 table {V(Tj,gnd)} = (-40, 13.6236, -20, 13.6451, 0, 13.6639, 25, 13.6747, 50, 13.6747, 100, 13.6666,
*+ 150, 13.6559)
*EVthrL9 VthrL9 0 table {V(Tj,gnd)} = (-40, 12.8683, -20, 12.8844, 0, 12.9005, 25, 12.9086, 50, 12.9113, 100, 12.9059,
*+ 150, 12.8978)
EVthrH9 VthrH9 0 value = {14.9}
EVthrL9 VthrL9 0 value = {14.4}

Rinp inp gnd 1G
Rinm inm gnd 1G

*Gthr gnd thr Value= { IF ( V(out,gnd) < {VoutM}, {VthH}, {VthL}) }
*Gthr gnd thr Value= { IF ( V(out,gnd) < VoutM, V(VthrH), V(VthrL) ) }
Gthr gnd thr Value= { IF ( V(out,gnd) < VoutM, 
+ IF ( Y == 6, V(VthrH6), IF (Y == 7, V(VthrH7), IF (Y == 8, V(VthrH8), V(VthrH9)))),
+ IF ( Y == 6, V(VthrL6), IF (Y == 7, V(VthrL7), IF (Y == 8, V(VthrL8), V(VthrL9)))) ) } 

Rthr gnd thr 1

Gouti gnd outi Value= { IF ( (V(inp,inm) > V(thr,gnd)), (VoutH - V(outi,gnd))*Gdlh, (VoutL - V(outi,gnd))*Gdhl ) }
Couti outi gnd {Cdel}
Routi outi gnd 1G

Gthro gnd thro Value= { IF ( V(out,gnd) < VoutM, VoutH*0.99, VoutH*0.01 ) }
Rthro gnd thro 1
*Gout gnd out Value= { IF ( (V(outi, gnd) > VoutM), (VoutH - V(out,gnd))*Gr, (VoutL - V(out,gnd))*Gf ) }
Gout gnd out Value= { IF ( (V(outi, gnd) > V(thro,gnd)), (VoutH - V(out,gnd))*Gr, (VoutL - V(out,gnd))*Gf ) }
Cout out gnd {Cout}
Rout out gnd 1G
.ENDS

.SUBCKT HYSTCOMPG_THLRF_LONGDEL_1EDB7275F_1 inp inm out gnd Tj
+ Params: Vthres=0 Vhyst=1 VoutH=5 VoutL=0 Rout=1 Tdlh=1N Tdhl=1N Trise=1N Tfall=1N 
* Trise ->   90%*(VoutH-VoutL), Tfall -> 10%*(VoutH-VoutL)
.PARAM MinADel = 100p
.PARAM Tdellh = {MAX(Tdlh,MinADel)}
.PARAM Tdelhl = {MAX(Tdhl,MinADel)}
.Param Rdel = {IF ( ((Tdellh > 1E-15)|(Tdelhl > 1E-15)) & (Rout < 1), 1, Rout ) } 
.Param Ro = {IF ( ((Trise > 1E-15)|(Tfall > 1E-15)) & (Rout < 1), 1, Rout ) } 
.Param VoutM={(VoutH+VoutL)/2}
*.Param VthH={Vthres+Vhyst}
*.Param VthL={Vthres-Vhyst}
.Param Tdmin= 1p
*.Param Cdel={Sqrt((Tdelhl+Tdmin)*(Tdellh+Tdmin))/(0.693*(Rdel+1u))}
*.Param Cdel={Sqrt((Tdelhl+Tdmin)*(Tdellh+Tdmin))/(4.6*(Rdel+1u))}
.Param Cdel={Sqrt((Tdelhl+Tdmin)*(Tdellh+Tdmin))/(4.3*(Rdel+1u))}
.Param Gdlh={Sqrt((Tdelhl+Tdmin)/(Tdellh+Tdmin))/Rdel}
.Param Gdhl={(Tdellh+Tdmin)/(Tdelhl+Tdmin)*Gdlh}
.Param Cout={Sqrt(Tfall*Trise)/(2.287*(Ro+1u))}
.Param Gr={Sqrt(Tfall/(Trise+Tdmin))/Ro}
.Param Gf={(Trise+Tdmin)/Tfall*Gr}

EVthrH VthrH 0 table {V(Tj,gnd)} = (-40.18, 2.8364, -19.898, 2.8411, 0, 2.8449, 24.87, 2.8504, 50.51, 2.8551, 100.25, 2.8598,
+ 150, 2.8617)
EVthrL VthrL 0 table {V(Tj,gnd)} = (-40.18, 2.6486, -19.898, 2.6514, 0, 2.6551, 24.87, 2.6579, 50.51, 2.6588, 100.25, 2.6607,
+ 150, 2.6626)

Rinp inp gnd 1G
Rinm inm gnd 1G

*Gthr gnd thr Value= { IF ( V(out,gnd) < {VoutM}, {VthH}, {VthL}) }
Gthr gnd thr Value= { IF ( V(out,gnd) < VoutM, V(VthrH), V(VthrL) ) }
Rthr gnd thr 1

Gouti gnd outi Value= { IF ( (V(inp,inm) > V(thr,gnd)), (VoutH - V(outi,gnd))*Gdlh, (VoutL - V(outi,gnd))*Gdhl ) }
Couti outi gnd {Cdel}
Routi outi gnd 1G

Gthro gnd thro Value= { IF ( V(out,gnd) < VoutM, VoutH*0.99, VoutH*0.01 ) }
Rthro gnd thro 1
*Gout gnd out Value= { IF ( (V(outi, gnd) > VoutM), (VoutH - V(out,gnd))*Gr, (VoutL - V(out,gnd))*Gf ) }
Gout gnd out Value= { IF ( (V(outi, gnd) > V(thro,gnd)), (VoutH - V(out,gnd))*Gr, (VoutL - V(out,gnd))*Gf ) }
Cout out gnd {Cout}
Rout out gnd 1G
.ENDS

