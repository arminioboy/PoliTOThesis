Plecs {
  Name          "PFC_incremental"
  Version       "4.9"
  CircuitModel  "ContStateSpace"
  StartTime     "0.0"
  TimeSpan      "0.2"
  Timeout       ""
  Solver        "radau"
  MaxStep       "1e-3"
  InitStep      "-1"
  FixedStep     "1e-3"
  Refine        "1"
  ZCStepSize    "1e-9"
  RelTol        "1e-3"
  AbsTol        "-1"
  TurnOnThreshold "0.7"
  NonIdealSwitchResistance "1"
  SyncFixedStepTasks "2"
  UseSingleCommonBaseRate "2"
  LossVariableLimitExceededMsg "2"
  NegativeSwitchLossMsg "3"
  DivisionByZeroMsg "3"
  DatatypeOverflowMsg "2"
  DatatypeInheritanceConflictMsg "1"
  ContSampleTimeConflictMsg "1"
  StiffnessDetectionMsg "2"
  MaxConsecutiveZCs "1000"
  AlgebraicLoopWithStateMachineMsg "2"
  AssertionAction "3"
  FixedPointDatatypeOverride "1"
  InitializationCommands "% Grid\nVin = 220*sqrt(2); % Grid voltage (V)\nF = 5"
"0.0; % Grid frequency (Hz)\n\n%modification here\nL1=7.5e-6;\nRl1=2.11e-3;\nC"
"l1=4e-12;\nRp1=3.209e3;\n\nL2=6.2e-6;\nRl2=1.05e-3;\nCl2=6.5e-12;\nRp2=1.5e3;"
"\n\nCout=330e-6;\nVout=400;\ndeadtime=10e-9\nSlow_leg_deadtime=400e-9;\n%end "
"modifications\n\n%thermal\nRth_ch = 0.1;\t\t% Case-to-heatsink thermal resist"
"ance (TIM) (K/W) [0:20]\nRth_ha = 0.5;\t\t% Heatsink-to-ambient thermal resis"
"tance (K/W) [0:20]\nRth_pcb = 0.5;\t\t% Heatsink-to-ambient thermal resistanc"
"e (K/W) [0:20]\n%tao_ha = 1;\t\t% Heatsink time constant (s) [0:100]\n%Cth = "
"tao_ha/Rth_ha; % Heatsink thermal capacitance (J/K)\nTamb = 45;\t\n%end therm"
"al\n\n% Plant\nC = Cout*5; % Output capacitor (C)\nL = L1+L2; % Choke inducta"
"nce (H)\nRl = Rl1+Rl2; % Choke resistance (ohms)\n\nfs = 140e3; % Switching f"
"requency (Hz)\n\n% Current Compensator\nRi.F = 50e3; % Current control loop f"
"requency (Hz)\nRi.Ts = 1/Ri.F; % sample time\nRi.Tp = Ri.Ts/2.0; % Average PW"
"M delay (s)\n\nRi.Ti = 2/Rl*Ri.Tp; \nRi.Tn = L/Rl;\n\nRi.Kp = Ri.Tn/Ri.Ti;\nR"
"i.Ki = 1/Ri.Ti;\n\n% Voltage Compensator\nRv.F = 2e3; % Voltage control loop "
"frequency (Hz)\nRv.Ts = 1/Rv.F; % sample time\nRv.Tp = Rv.Ts/2*10; % equivale"
"nt delay (s)\n\nRv.Ti = 8/C*Rv.Tp*Rv.Tp;\nRv.Tn = 4*Rv.Tp;\n\nRv.Kp = Rv.Tn/R"
"v.Ti;\nRv.Ki = 1/Rv.Ti;"
  InitialState  "1"
  SystemState   ""
  TaskingMode   "1"
  TaskConfigurations ""
  CodeGenParameterInlining "2"
  CodeGenFloatingPointFormat "2"
  CodeGenAbsTimeUsageMsg "3"
