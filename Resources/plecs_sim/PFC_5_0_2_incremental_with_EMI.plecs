  Script {
    Name          "Power_sweep"
    Script        "% Clear all previous traces in scope 'Scope' in the current"
" model\nplecs('clc');\nplecs('scope', './Losses_measure/All_losses','ClearTra"
"ces');\n\n% Evaluate simulation results in callback function\nfunction result"
" = callback(index, data)\n   % hold and label trace\n\tFile = ['/home/giorgio"
"/Documenti/PolitoMaterial/Tesi/PoliTOThesis/Resources/plecs_sim/PFC_sim_resul"
"ts/variable_load/', mat2str(PowerOutput(index)), 'W.csv'];\n\tplecs('scope', "
"'./Losses_measure/All_losses', 'ExportCSV', File);\n\t\n\tif isstruct(data)\n"
"\t\t% Reducing simulation results by return value 'result' \n \t\tresult = 0;"
"\n \telse\n \t\t% Print error message to Octave console\n \t\tprintf(' Error "
"in Simulation %d for Power=%dW: %s\\n',\n                  index, PowerOutput"
"(index), data);\n\tend\nend\n\n% Set value to be swept\nPowerOutput = [3350:5"
"0:5000]; % start step stop\n% Initialize simStruct as cell array with all val"
"ues\nfor ix = 1:length(PowerOutput)\n\tsimStructs{ix}.ModelVars.Pout = PowerO"
"utput(ix);\n% Name of 'ModelVars' can be assigned for diagnostic purposes\t\n"
"\tsimStructs{ix}.Name = ['Power=' mat2str(PowerOutput(ix)) 'W'];\nend\n\n% St"
"art simulation, return result from callback function into 'out'\n% Analysis w"
"ill be moved to callback function to reduce simulation results\nout = plecs('"
"simulate', simStructs, @(index, data) callback(index, data));\n\nfor ix = 1:l"
"ength(PowerOutput)\n\tprintf(' Simulation for Power=%dW: started\\n',PowerOut"
"put(ix));\n\t% Detect if errors occurred in parallel simulation \n   if ischa"
"r(out{ix})\n   \tprintf(' Error for P=%dW: %s\\n',PowerOutput(ix), out{ix});"
"\n   else\n \t\tprintf(' Simulation for Power=%dW: terminated\\n',PowerOutput"
"(ix));\n\tend\nend"
  }
