Plecs {
  Name          "PFC"
  Version       "4.9"
  CircuitModel  "ContStateSpace"
  StartTime     "0.0"
  TimeSpan      "0.1"
  Timeout       ""
  Solver        "radau"
  MaxStep       "1e-3"
  InitStep      "-1"
  FixedStep     "1e-3"
  Refine        "1"
  ZCStepSize    "1e-9"
  RelTol        "1e-3"
  AbsTol        "-1"
  TurnOnThreshold "0"
  NonIdealSwitchResistance "1"
  SyncFixedStepTasks "2"
  UseSingleCommonBaseRate "2"
  LossVariableLimitExceededMsg "2"
  NegativeSwitchLossMsg "3"
  DivisionByZeroMsg "3"
  DatatypeOverflowMsg "2"
  DatatypeInheritanceConflictMsg "1"
  ContSampleTimeConflictMsg "1"
  StiffnessDetectionMsg "2"
  MaxConsecutiveZCs "1000"
  AlgebraicLoopWithStateMachineMsg "2"
  AssertionAction "3"
  FixedPointDatatypeOverride "1"
  InitializationCommands "% Grid\nVin = 220*sqrt(2); % Grid voltage (V)\nF = 5"
"0.0; % Grid frequency (Hz)\n\n%modification here\nL1=7.5e-6;\nRl1=2.11e-3;\nC"
"l1=4e-12;\nRp1=3.209e3;\n\nL2=6.2e-6;\nRl2=1.05e-3;\nCl2=6.5e-12;\nRp2=1.5e3;"
"\n\nCout=330e-6;\nVout=400;\n%end modifications\n\n% Plant\nC = Cout*5; % Out"
"put capacitor (C)\nL = L1+L2; % Choke inductance (H)\nRl = Rl1+Rl2; % Choke r"
"esistance (ohms)\n\nfs = 140e3; % Switching frequency (Hz)\n\n% Current Compe"
"nsator\nRi.F = 50e3; % Current control loop frequency (Hz)\nRi.Ts = 1/Ri.F; %"
" sample time\nRi.Tp = Ri.Ts/2.0; % Average PWM delay (s)\n\nRi.Ti = 2/Rl*Ri.T"
"p; \nRi.Tn = L/Rl;\n\nRi.Kp = Ri.Tn/Ri.Ti;\nRi.Ki = 1/Ri.Ti;\n\n% Voltage Com"
"pensator\nRv.F = 2e3; % Voltage control loop frequency (Hz)\nRv.Ts = 1/Rv.F; "
"% sample time\nRv.Tp = Rv.Ts/2*10; % equivalent delay (s)\n\nRv.Ti = 8/C*Rv.T"
"p*Rv.Tp;\nRv.Tn = 4*Rv.Tp;\n\nRv.Kp = Rv.Tn/Rv.Ti;\nRv.Ki = 1/Rv.Ti;\n\n% The"
"rmal\nRth_ch = 0.1;\t\t% Case-to-heatsink thermal resistance (TIM) (K/W) [0:2"
"0]\nRth_ha = 0.5;\t\t% Heatsink-to-ambient thermal resistance (K/W) [0:20]\nR"
"th_pcb = 0.5;\t\t% Heatsink-to-ambient thermal resistance (K/W) [0:20]\ntao_h"
"a = 1;\t\t% Heatsink time constant (s) [0:100]\nCth = tao_ha/Rth_ha; % Heatsi"
"nk thermal capacitance (J/K)\nTamb = 75;\t\t\t% Ambient temperature (C) [-50:"
"150]"
  InitialState  "1"
  SystemState   ""
  TaskingMode   "1"
  TaskConfigurations "AAAACQAAAAACAAAACAAAAAAGAAAACABDAG8AcgBlAAAAAgAAAAAAAAAA"
