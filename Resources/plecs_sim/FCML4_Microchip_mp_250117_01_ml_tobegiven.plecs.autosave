  Refine        "1"
  ZCStepSize    "1e-9"
  RelTol        "1e-5"
  AbsTol        "-1"
  TurnOnThreshold "0"
  NonIdealSwitchResistance "1"
  SyncFixedStepTasks "2"
  UseSingleCommonBaseRate "2"
  LossVariableLimitExceededMsg "3"
  NegativeSwitchLossMsg "3"
  DivisionByZeroMsg "3"
  DatatypeOverflowMsg "2"
  DatatypeInheritanceConflictMsg "1"
  ContSampleTimeConflictMsg "1"
  StiffnessDetectionMsg "2"
  MaxConsecutiveZCs "1000"
  AlgebraicLoopWithStateMachineMsg "2"
  AssertionAction "1"
  FixedPointDatatypeOverride "1"
  InitializationCommands "%DC Tests Open Loop\ndirection = 1;\n%direction=1 or"
" -1;\nvinmax = 340;\nabsvin = 100/100*vinmax;\nvin  = direction*absvin;\nvout"
" = 400;\ndutyl = 1-(absvin/vout);\nioutmax= 12.5;\niinmax = ioutmax*vout/vinm"
"ax;\niin = absvin/vinmax*iinmax*direction;\niout =iin*vin/vout;\n%rout = vout"
"/iout;\nrout = 32;\ndeadtime=15e-9; %50 ns deadtime\n% Grid\nVinrms=240;\nVin"
" = Vinrms*sqrt(2); % Grid voltage (V)\nF = 50.0; % Grid frequency (Hz)\n%fs ="
" 100e3; % Switching frequency (Hz)\n%fs = 140e3*3; % Switching frequency (Hz)"
" equivalent to 4 level\nfs = 140e3; % Switching frequency (Hz) \n\nmis_cycles"
" = 0; %max misalignment is +/-8 at 70 kHz\n%mis_time=mis_cycles/(fs); %140 kH"
"z\nmis_time=mis_cycles/(fs/2); %70 kHz\nmisalignment= mis_time*F*360;\n\nkvbu"
"s= 1/500;\nkvac= 1/500;\nkil= 1/50;\n\n\n\n% Plant\n%C = 400e-6; % Output cap"
"acitor (C)\n%L = 1.5e-3; % Choke inductance (H)\nC = 880e-6; % Output capacit"
"or (C)\nL = 0.0135e-3; % Choke inductance (H)\n\nRl = 0.001; % Choke resistan"
"ce (ohms)\n\n% Current Compensator\nRi.F = 50e3; % Current control loop frequ"
"ency (Hz)\nRi.Ts = 1/Ri.F; % sample time\nRi.Tp = Ri.Ts/2.0; % Average PWM de"
"lay (s)\n\nRi.Ti = 2/Rl*Ri.Tp; \nRi.Tn = L/Rl;\n\nRi.Kp = Ri.Tn/Ri.Ti;\nRi.Ki"
" = 1/Ri.Ti;\n\n% Voltage Compensator\nRv.F = 2e3; % Voltage control loop freq"
"uency (Hz)\nRv.Ts = 1/Rv.F; % sample time\nRv.Tp = Rv.Ts/2*10; % equivalent d"
"elay (s)\n\nRv.Ti = 8/C*Rv.Tp*Rv.Tp;\nRv.Tn = 4*Rv.Tp;\n\nRv.Kp = Rv.Tn/Rv.Ti"
";\nRv.Ki = 1/Rv.Ti;\n\nk=2;"
